# Copy to .env and adjust. NEVER commit real secrets.
ENV=docker
DEBUG=false

# SQLite (zero-setup local/dev/test):
# DATABASE_URL=sqlite:///./fbgroup.db
# PostgreSQL (Docker/prod) — psycopg v3 driver:
DATABASE_URL=postgresql+psycopg://fbgroup:fbgroup@db:5432/fbgroup

# Auth — generate a strong random value in production (e.g. `openssl rand -hex 32`)
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP mock
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5

# Rate limits (per minute)
RATE_LIMIT_OTP_PER_MIN=5
RATE_LIMIT_LOGIN_PER_MIN=10

# SG money rules
GST_RATE=0.09
SERVICE_CHARGE_RATE=0.10

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Seed demo data on container start (1=yes)
SEED_ON_START=1

# AI Insights advisor — leave AI_ENABLED=0 to use the deterministic heuristic
# (no key/network/cost). Set AI_ENABLED=1 + a real key to switch to Claude.
AI_ENABLED=0
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-7
AI_MAX_TOKENS=4096
